# 复制为 .secrets.env 并填好真实值(我会 source 它,但不会读取/打印内容)。
#   cp .secrets.env.template .secrets.env  然后编辑

# Bedrock API key(bearer token)
export AWS_BEARER_TOKEN_BEDROCK="填你的-bedrock-api-key"

# 区域:需在该区已开通下面两个模型的访问
export AWS_REGION_NAME="us-east-1"

# 两个“不同 model ID” = 两个独立缓存域(格式带 bedrock/ 前缀)
# 需是该账户在该区已开通、且支持 prompt caching 的模型
export BEDROCK_MODEL_A="bedrock/anthropic.claude-3-7-sonnet-20250219-v1:0"
export BEDROCK_MODEL_B="bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0"
